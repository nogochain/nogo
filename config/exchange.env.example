# NogoChain Exchange Integration Configuration
# Production-grade security settings for exchange deployment
# Copy this file to .env and modify as needed

# =============================================================================
# Rate Limiting Configuration (Exchange High-Concurrency Mode)
# =============================================================================
# Requests per second: Set to 1000+ for exchange batch operations
NOGO_API_RATE_LIMIT_RPS=1000
# Burst capacity: Allow 5x RPS for burst traffic (withdrawal batches, etc.)
NOGO_API_RATE_LIMIT_BURST=5000
# Enable rate limiting: Always enable in production
NOGO_API_RATE_LIMIT_ENABLED=true

# =============================================================================
# Request Body Size Limits
# =============================================================================
# Maximum request body size in MB: 20MB for batch transaction submissions
# Standard: 10MB | Exchange: 20MB (supports up to 50 txs per batch)
NOGO_API_MAX_REQUEST_BODY_MB=20

# =============================================================================
# Security Headers Configuration
# =============================================================================
# Enable security headers: Adds HSTS, CSP, X-Frame-Options, etc.
NOGO_API_SECURITY_HEADERS_ENABLED=true

# CORS configuration: Allow all origins for exchange callbacks
# For production, restrict to your exchange domain: https://exchange.example.com
NOGO_API_CORS_ALLOW_ORIGINS=*

# =============================================================================
# Node Mode Selection (Choose ONE)
# =============================================================================
# Option A: Exchange Mode (Recommended for exchange nodes)
# Uncomment the following line in your startup script:
#   export NOGO_EXCHANGE_MODE=true

# Option B: Public Node Mode (For community full nodes)
# Default settings are optimized for public access

# =============================================================================
# Admin Security (Critical for Exchange Operations)
# =============================================================================
# Admin token: Required for mining and administrative endpoints
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=your_secure_admin_token_here_minimum_32_characters

# Trust proxy: Set to true if behind load balancer/reverse proxy
TRUST_PROXY=true

# =============================================================================
# Logging and Monitoring Configuration
# =============================================================================
# Structured logging format: json or text
API_LOGGING_FORMAT=json
API_LOGGING_LEVEL=info

# Enable Prometheus metrics endpoint
API_METRICS_ENABLED=true
API_METRICS_PATH=/metrics
API_METRICS_PORT=9091

# Enable audit logging for compliance
API_AUDIT_LOG_ENABLED=true
API_AUDIT_LOG_DIR=./logs/audit

# =============================================================================
# TLS Configuration (Required for Mainnet)
# =============================================================================
# Enable TLS: Always true in production
API_TLS_ENABLED=true
API_TLS_CERT_FILE=/etc/nogo/tls/cert.pem
API_TLS_KEY_FILE=/etc/nogo/tls/key.pem
API_TLS_MIN_VERSION=TLS1.2

# =============================================================================
# WebSocket Configuration (For Real-time Updates)
# =============================================================================
# Enable WebSocket for real-time block/transaction notifications
API_WEBSOCKET_ENABLED=true
API_WEBSOCKET_MAX_CONNS=1000
API_WEBSOCKET_READ_TIMEOUT=30s
API_WEBSOCKET_WRITE_TIMEOUT=30s

# =============================================================================
# Example: Exchange Startup Script (bash)
# =============================================================================
#!/bin/bash
# exchange_node.sh - Start NogoChain node optimized for exchange integration

set -e

echo "========================================="
echo "🚀 Starting NogoChain Exchange Node"
echo "========================================="

# Load environment variables from this file
source "$(dirname "$0")/.env.exchange"

# Validate critical configurations
if [ -z "$ADMIN_TOKEN" ] || [ ${#ADMIN_TOKEN} -lt 32 ]; then
    echo "❌ ERROR: ADMIN_TOKEN must be set and at least 32 characters"
    exit 1
fi

echo "📊 Security Configuration:"
echo "   - Rate Limit: ${NOGO_API_RATE_LIMIT_RPS} RPS / ${NOGO_API_RATE_LIMIT_BURST} burst"
echo "   - Max Body Size: ${NOGO_API_MAX_REQUEST_BODY_MB}MB"
echo "   - TLS Enabled: ${API_TLS_ENABLED}"
echo "   - WebSocket: ${API_WEBSOCKET_ENABLED}"

# Start node with production flags
exec ./nogo \
    --chain-id=1 \
    --data-dir=/var/lib/nogo/data \
    --http-addr=0.0.0.0:8080 \
    --p2p-listen=:9090 \
    --mining-enabled=false \
    --admin-token="${ADMIN_TOKEN}" \
    --trust-proxy=${TRUST_PROXY:-false}
