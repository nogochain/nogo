# Example mainnet env (single-node). Copy to .env.mainnet and edit as needed.
# Generate a fresh one via: ./scripts/mainnet_bootstrap.sh .env.mainnet

CHAIN_ID=1
GENESIS_PATH=genesis/mainnet.json

# Require peers to match rules + genesis (recommended for any real network)
# STRICT_PEER_IDENTITY=true

MINER_ADDRESS=<hex address>

# Optional hardening (recommended if you bind beyond localhost)
# ADMIN_TOKEN=change-me

# Bind address (default is :8080 inside container; docker publishes to 127.0.0.1 by default)
# HTTP_ADDR=:8080

# P2P Configuration - Unified port for peer connections
NOGO_P2P_PORT=9090
NOGO_P2P_PEERS=main.nogochain.org:9090,wallet.nogochain.org:9090,node.nogochain.org:9090

# Encryption mode for P2P connections (none/nacl/tls/both)
NOGO_ENCRYPTION_MODE=both

# Log level (debug/info/warn/error)
NOGO_LOG_LEVEL=info

# Basic rate limiting (set both to enable)
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_BURST=40
